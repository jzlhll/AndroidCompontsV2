<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_normal_block0">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/logic_middle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/title" />

    <com.au.module_androidui.widget.CustomToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/icon_back"
        app:navigationIconTint="#ffffff"
        app:title="@string/text_chat_room"
        app:titleCentered="true"
        app:titleTextColor="#ffffff" />

    <com.au.module_androidui.widget.CustomFontText
        android:id="@+id/title"
        style="@style/StyleAuTextThin"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginTop="4dp"
        android:gravity="center_horizontal"
        android:textColor="#ffffff"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:text="192.168.1.2:8080" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRcv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/inputHost"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title"
        tools:listitem="@layout/holder_text_chat_message" />

    <LinearLayout
        android:id="@+id/inputHost"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/color_normal_block"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.au.module_androidui.widget.CustomEditText
            android:id="@+id/inputEdit"
            style="@style/StyleBlankEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:hint="@string/text_chat_input_hint"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:layout_marginBottom="18dp"
            android:maxLines="1"
            android:layout_marginTop="8dp"
            android:minHeight="32dp"
            android:singleLine="true"
            tools:text="你好，先只做一个本地文本聊天界面" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
