<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_normal_block0">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/logic_middle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/title" />

    <com.au.module_androidui.widget.CustomToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/icon_back"
        app:navigationIconTint="#ffffff"
        app:title="@string/text_chat_room"
        app:titleCentered="true"
        app:titleTextColor="#ffffff" />

    <com.au.module_androidui.widget.CustomFontText
        android:id="@+id/title"
        style="@style/StyleAuTextThin"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginTop="4dp"
        android:gravity="center_horizontal"
        android:textColor="#ffffff"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:text="192.168.1.2:8080" />

    <LinearLayout
        android:id="@+id/clientsHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/title" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRcv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/inputHost"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clientsHost"
        tools:listitem="@layout/holder_text_chat_message" />

    <LinearLayout
        android:id="@+id/inputHost"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/color_normal_block"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <com.au.module_androidui.widget.CustomEditText
                android:id="@+id/inputEdit"
                style="@style/StyleBlankEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="top|start"
                android:hint="@string/text_chat_input_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:maxHeight="120dp"
                android:minHeight="40dp"
                android:overScrollMode="ifContentScrolls"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:scrollbars="vertical"
                tools:text="你好，先只做一个本地文本聊天界面" />

            <com.au.module_androidui.widget.CustomButton
                android:id="@+id/sendBtn"
                android:layout_width="72dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:text="@string/send"
                android:textColor="#ffffff"
                android:gravity="center"
                android:textSize="15sp"
                app:backgroundNormal="#069a4a"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
